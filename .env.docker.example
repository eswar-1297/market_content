# Copy to .env (next to docker-compose.yml) and fill in.
# docker compose reads this file automatically.

# Postgres password (used by both the db service and DATABASE_URL)
POSTGRES_PASSWORD=changeme

# Public base URL of the app (used for email tracking links)
APP_BASE_URL=http://localhost:3001

# --- AI providers (at least one) ---
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# --- Optional integrations ---
YOUTUBE_API_KEY=
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# --- Microsoft Entra ID auth (REQUIRED for per-user history) ---
AUTH_TENANT_ID=
AUTH_CLIENT_ID=
