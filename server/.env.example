OPENAI_API_KEY=your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
YOUTUBE_API_KEY=your-youtube-api-key-here
GOOGLE_CSE_KEY=your-google-cse-api-key-here
GOOGLE_CSE_CX=your-google-cse-cx-id-here
ATP_API_KEY=
RAPIDAPI_KEY=
SENDGRID_API_KEY=your-sendgrid-api-key-here
SENDGRID_FROM_EMAIL=noreply@cloudfuze.com
SENDGRID_FROM_NAME=CloudFuze
COPYLEAKS_EMAIL=your-copyleaks-email-here
COPYLEAKS_API_KEY=your-copyleaks-api-key-here
APP_BASE_URL=http://localhost:3001

# Microsoft Login (User Authentication via Entra ID / Azure AD)
# This is a SEPARATE app registration from SharePoint — SPA type, no client secret needed
AUTH_TENANT_ID=your-azure-ad-tenant-id
AUTH_CLIENT_ID=your-auth-app-registration-client-id

# SharePoint Integration (Microsoft Graph API) — server-to-server, separate app registration
MS_TENANT_ID=your-azure-ad-tenant-id
MS_CLIENT_ID=your-sharepoint-app-registration-client-id
MS_CLIENT_SECRET=your-sharepoint-app-registration-client-secret
SHAREPOINT_HOST=cloudfuzecom.sharepoint.com
SHAREPOINT_SITE=DOC360

# Reddit API (required for thread discovery — 403 without OAuth)
# Create app at https://www.reddit.com/prefs/apps/ (select "script" type)
REDDIT_CLIENT_ID=your-reddit-app-client-id
REDDIT_CLIENT_SECRET=your-reddit-app-secret
REDDIT_USERNAME=your-reddit-username

# Ollama (local/self-hosted LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Langfuse (LLM Observability — optional)
# Get keys from https://cloud.langfuse.com or your self-hosted instance
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://us.cloud.langfuse.com
